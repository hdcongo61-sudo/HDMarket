# PawaPay Merchant API (server-side only)
PAWAPAY_ENABLED=false
# Disable manual transaction IDs and use PawaPay as the only customer payment gateway.
PAWAPAY_EXCLUSIVE_MODE=false
PAWAPAY_ENVIRONMENT=sandbox
PAWAPAY_API_TOKEN=
# Optional override; normally inferred from PAWAPAY_ENVIRONMENT.
# PAWAPAY_BASE_URL=https://api.sandbox.pawapay.io/v2

# Content-Digest is validated whenever PawaPay sends it. Require it after
# callbacks are enabled in your PawaPay dashboard.
PAWAPAY_CONTENT_DIGEST_REQUIRED=false
# When true, callback signatures are verified with PawaPay's rotating public
# keys fetched from /v2/public-key/http. Enable signed callbacks first in PawaPay.
PAWAPAY_SIGNED_CALLBACKS_REQUIRED=false

# Hosted checkout sends the browser here after payment. This is not a callback URL.
PAWAPAY_CHECKOUT_RETURN_URL=https://www.hdmarket.store/payment/pawapay/return
