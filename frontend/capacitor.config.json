{
  "appId": "com.hdmarket.app",
  "appName": "HDMarket",
  "webDir": "dist",
  "ios": {
    "scheme": "hdmarket",
    "contentInset": "automatic",
    "allowsLinkPreview": true,
    "scrollEnabled": true
  },
  "android": {
    "allowMixedContent": true
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 2000,
      "backgroundColor": "#FF6A00",
      "showSpinner": false
    }
  }
}
